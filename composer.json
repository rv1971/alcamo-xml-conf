{
    "name": "alcamo/xml-conf",
    "description": "Simple reading of XML conf files from XDG base directories",
    "keywords": [ "xml", "conf", "configuration", "xdg" ],
    "license": "Apache-2.0",
    "require": {
        "php": "7.3 - 8.5",
        "alcamo/conf": "^0.6",
        "alcamo/dom": "^0.17"
    },
    "autoload": {
	"psr-4": {
	    "alcamo\\xml_conf\\": "src/"
	}
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "3.*"
    },
    "scripts": {
        "test": [
            "phpunit tests",
            "phpcs --standard=PSR12 -p -s src",
            "phpcs --standard=PSR12 -p -s --exclude=PSR1.Classes.ClassDeclaration,PSR1.Files.SideEffects tests"
        ],
        "fix": [
            "phpcbf --standard=PSR12 -p -s src",
            "phpcbf --standard=PSR12 -p -s --exclude=PSR1.Classes.ClassDeclaration,PSR1.Files.SideEffects tests"
        ]
    }
}
